{
  "version": 1,
  "product": "AI Video Tool",
  "release": {
    "github_repo": "Druttzen/ai-video-studio",
    "engine_tag": "v0.2.5",
    "tag": "v0.2.5",
    "downloads": {
      "engine_win64": {
        "filename": "ave-engine-win64.7z",
        "archive": "7z",
        "folder": "ave-engine",
        "approx_size_gb": 1.6,
        "sha256": "97a7209d59cea5061cb62f6a0d35b4b194197b58f6ddf82912ff2fa98be6e47a"
      },
      "webview2_bootstrapper": {
        "url": "https://go.microsoft.com/fwlink/p/?LinkId=2124703",
        "filename": "MicrosoftEdgeWebView2RuntimeInstaller.exe"
      }
    }
  },
  "components": [
    {
      "id": "engine",
      "name": "AI Engine (PyTorch + pipelines)",
      "folder": "ave-engine",
      "executable": "ave-engine.exe",
      "required": true,
      "approx_size_gb": 5.0,
      "description": "Local inference runtime. Required for generation."
    },
    {
      "id": "webview2",
      "name": "Microsoft WebView2 Runtime",
      "required": true,
      "check": "registry:HKLM\\SOFTWARE\\WOW6432Node\\Microsoft\\EdgeUpdate\\Clients\\{F3017226-FE2A-4295-8BDF-00C3A9A7E4C5}\\pv",
      "description": "UI shell (preinstalled on most Windows 10/11 systems)."
    },
    {
      "id": "data_dir",
      "name": "Model & output data folder",
      "required": true,
      "min_free_gb": 35,
      "description": "Hugging Face model cache and rendered videos."
    }
  ],
  "models": [
    {
      "id": "ltx-video",
      "name": "LTX-Video",
      "default": true,
      "approx_size_gb": 28,
      "min_vram_gb": 8,
      "min_free_gb": 35,
      "description": "Fast text/image-to-video. Recommended default."
    },
    {
      "id": "cogvideox-2b",
      "name": "CogVideoX-2B",
      "default": false,
      "approx_size_gb": 12,
      "min_vram_gb": 8,
      "min_free_gb": 15,
      "description": "High-quality text-to-video (Apache-2.0)."
    },
    {
      "id": "svd-xt",
      "name": "Stable Video Diffusion XT",
      "default": false,
      "approx_size_gb": 9.5,
      "min_vram_gb": 10,
      "min_free_gb": 12,
      "commercial": false,
      "description": "Image-to-video. Non-commercial license."
    }
  ],
  "optional_addons": [
    {
      "id": "wav2lip",
      "name": "Wav2Lip lip-sync",
      "folder": "addons\\wav2lip",
      "required": false,
      "approx_size_gb": 0.5,
      "description": "Lip-sync for music videos.",
      "github_zip": "https://github.com/Rudrabha/Wav2Lip/archive/refs/heads/master.zip",
      "zip_strip_prefix": "Wav2Lip-master",
      "checkpoint": {
        "url": "https://huggingface.co/numz/wav2lip_studio/resolve/main/wav2lip_gan.pth",
        "dest": "checkpoints/wav2lip_gan.pth",
        "approx_bytes": 436000000
      },
      "env_var": "AVE_WAV2LIP_DIR"
    }
  ],
  "install_phases": [
    { "id": "platform", "title": "Platform & runtime", "description": "Engine, WebView2, data folder, tools" },
    { "id": "engine", "title": "AI engine stack", "description": "Verify PyTorch, diffusers, and audio libs (fail-safe)" },
    { "id": "models", "title": "Hugging Face models", "description": "AI model weights from the Hub" },
    { "id": "addons", "title": "GitHub addons", "description": "Optional repos (e.g. Wav2Lip)" }
  ]
}
